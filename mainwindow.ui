       <item row="0" column="0">
        <widget class="QLabel" name="label_token">
         <property name="text">
          <string>Access Token:</string>
         </property>
        </widget>
       </item>

       <item row="0" column="1">
        <widget class="QLineEdit" name="accessTokenLineEdit">
         <property name="echoMode">
          <enum>QLineEdit::Password</enum>
         </property>
        </widget>
       </item>

       <item row="0" column="2">
        <widget class="QPushButton" name="fetchPagesButton">
         <property name="text">
          <string>Fetch Pages</string>
         </property>
        </widget>
       </item>

       <item row="1" column="0">
        <widget class="QLabel" name="label_page">
         <property name="text">
          <string>Select Page:</string>
         </property>
        </widget>
       </item>

       <item row="1" column="1" colspan="2">
        <widget class="QComboBox" name="pageComboBox"/>
