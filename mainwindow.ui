  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="mainLayout">

    <!-- ================= CREDENTIALS BOX ================= -->
    <item>
     <widget class="QGroupBox" name="credentialsBox">
      <property name="title">
       <string>API Credentials</string>
