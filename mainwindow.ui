         <property name="text">
          <string>Page ID:</string>
         </property>
        </widget>
       </item>

       <item row="2" column="1" colspan="2">
        <widget class="QLineEdit" name="pageIdLineEdit"/>
       </item>

       <item row="3" column="1">
        <widget class="QPushButton" name="saveSettingsButton">
         <property name="text">
          <string>Save Credentials</string>
         </property>
        </widget>
       </item>

      </layout>
     </widget>
    </item>

    <!-- ================= SCHEDULING BOX ================= -->
    <item>
     <widget class="QGroupBox" name="scheduleBox">
      <property name="title">
       <string>Scheduling Settings</string>
      </property>

      <layout class="QGridLayout" name="scheduleLayout">

       <item row="0" column="0">
        <widget class="QLabel" name="label_start">
         <property name="text">
          <string>Start Time:</string>
         </property>
