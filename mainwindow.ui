          </property>
         </item>
         <item>
          <property name="text">
           <string>Daily</string>
          </property>
         </item>
         <item>
          <property name="text">
           <string>Twice a Day (Every 12h)</string>
          </property>
         </item>
        </widget>
       </item>

      </layout>
     </widget>
